{"version":"V2.0","versionNumber":"V2.4.4","type":"core2","components":[{"name":"page0","type":"lvgl_page","layer":0,"screenId":"builtin","screenName":"","id":"g-WZWujg#=0cyNv2","createTime":1775488396446,"backgroundColor":"#ffffff","isLVGL":true,"isSelected":true}],"resources":[{"hardware":["hardware_button","hardware_pin_button","imu","speaker","touch","mic","sdcard"]}],"units":[],"hats":[],"caps":[],"chains":[],"bases":[],"plcmodules":[],"i2cs":[],"chainBus":[],"blockly":"<block type=\"basic_on_setup\" id=\"setup_block\" deletable=\"false\" x=\"50\" y=\"50\"><mutation isBegin=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_begin\" id=\"O+BUd(n=VhEr`2yo$}Vl\"><next><block type=\"lvgl_page_screen_load\" id=\"baax?NfQ+oW(me3TOud*\"><field name=\"NAME\">page0</field></block></next></block></statement></block><block type=\"basic_on_loop\" id=\"loop_block\" deletable=\"false\" x=\"450\" y=\"50\"><mutation isUpdate=\"true\"></mutation><field name=\"UPDATEOP\">true</field><statement name=\"FUNC\"><block type=\"system_m5_update\" id=\"c]Ru(aBUKU7Vxye:)/-k\"></block></statement></block>","screen":[{"simulationName":"Built-in","type":"builtin","width":320,"height":240,"scale":0.77,"screenName":"","blockId":"","screenColorType":0,"rotation":1,"id":"builtin","createTime":1775488396446}],"logicWhenNum":0,"pythonCode":"import time\nimport M5\nfrom M5 import *\nimport network\nimport json\nfrom machine import I2C, Pin\nfrom umqtt.simple import MQTTClient\nimport math\n\n# ======================\n# CONFIG\n# ======================\nFULL_NAME = \"your-name\"\nDEVICE_SUFFIX = \"001\"\n\nWIFI_SSID = \"your-wifi-ssid\"\nWIFI_PASSWORD = \"your-wifi-password!\"\n\nBROKER_IP = \"your-broker-ip\"\"\nBROKER_PORT = 1883\n\nLOCATION_ID = \"CLUB\" # change for each location\nSESSION_ID = \"run_1\" # change for each run\nDEVICE_ID = \"core2_{}\".format(DEVICE_SUFFIX)\nTOPIC = \"env/raw/{}\".format(LOCATION_ID)\nCLIENT_ID = \"vibechecker-{}\".format(DEVICE_SUFFIX)\n\nPUBLISH_SECONDS = 1\n\n# ======================\n# SENSOR CONFIG\n# ======================\nMIC_SAMPLE_RATE = 8000\nMIC_BUFFER_SIZE = 4000  # balanced\n\nMPU_ADDR = 0x68\nTEMP_OUT_H = 0x41\nPWR_MGMT_1 = 0x6B\nTEMP_OFFSET_C = 20.86\n\ni2c = None\n\n# ======================\n# STATE\n# ======================\nlast_valid_noise = 25.0\nlast_valid_temp = 70.0\n\nNOISE_ALPHA = 0.7\nTEMP_ALPHA = 0.9\n\n# ======================\n# LCD\n# ======================\ndef lcd_print(l1=\"\", l2=\"\", l3=\"\", l4=\"\"):\n    M5.Lcd.clear()\n    M5.Lcd.setTextSize(2)\n    M5.Lcd.setCursor(10, 20); M5.Lcd.print(l1)\n    M5.Lcd.setCursor(10, 50); M5.Lcd.print(l2)\n    M5.Lcd.setCursor(10, 80); M5.Lcd.print(l3)\n    M5.Lcd.setCursor(10, 110); M5.Lcd.print(l4)\n\n# ======================\n# TEMP\n# ======================\ndef wake_mpu():\n    try:\n        i2c.writeto_mem(MPU_ADDR, PWR_MGMT_1, b'\\x00')\n        time.sleep_ms(100)\n    except:\n        pass\n\ndef read_temp():\n    global last_valid_temp\n\n    try:\n        data = i2c.readfrom_mem(MPU_ADDR, TEMP_OUT_H, 2)\n        raw = (data[0] << 8) | data[1]\n\n        if raw & 0x8000:\n            raw -= 65536\n\n        temp_c = (raw / 326.8) + 25.0 - TEMP_OFFSET_C\n        temp_f = (temp_c * 9/5) + 32\n\n        if temp_f == 0 or abs(temp_f - last_valid_temp) > 5:\n            return last_valid_temp\n\n        temp_f = TEMP_ALPHA * last_valid_temp + (1 - TEMP_ALPHA) * temp_f\n\n        last_valid_temp = round(temp_f, 2)\n        return last_valid_temp\n\n    except:\n        return last_valid_temp\n\n# ======================\n# MIC INIT\n# ======================\ndef init_mic():\n    Mic.begin()\n\n# ======================\n# NOISE (FINAL)\n# ======================\ndef read_noise():\n    global last_valid_noise\n\n    try:\n        buf = bytearray(MIC_BUFFER_SIZE)\n\n        Mic.record(buf, MIC_SAMPLE_RATE, False)\n\n        start = time.time()\n        while Mic.isRecording():\n            M5.update()\n            time.sleep_ms(5)\n            if time.time() - start > 1:\n                break\n\n        num_samples = len(buf) // 2\n        if num_samples == 0:\n            return last_valid_noise\n\n        total_sq = 0\n        valid_samples = 0\n\n        for i in range(num_samples):\n            sample = buf[i*2] | (buf[i*2+1] << 8)\n            if sample & 0x8000:\n                sample -= 65536\n\n            if sample != 0:\n                total_sq += sample * sample\n                valid_samples += 1\n\n        if valid_samples == 0:\n            return last_valid_noise\n\n        rms = (total_sq / valid_samples) ** 0.5\n\n        # 🎯 calibrated to YOUR data (200–5000 range)\n        noise_db = 20 * math.log10((rms + 1) / 200) + 40\n\n        # clamp\n        noise_db = max(20, min(100, noise_db))\n\n        # smoothing\n        noise_db = NOISE_ALPHA * last_valid_noise + (1 - NOISE_ALPHA) * noise_db\n\n        last_valid_noise = round(noise_db, 2)\n        return last_valid_noise\n\n    except Exception as e:\n        print(\"Noise error:\", e)\n        return last_valid_noise\n\n# ======================\n# WIFI\n# ======================\ndef wifi_connect():\n    wlan = network.WLAN(network.STA_IF)\n\n    # Reset WiFi state first\n    wlan.active(False)\n    time.sleep(1)\n    wlan.active(True)\n    time.sleep(0.5)\n\n    lcd_print(\"Connecting WiFi...\")\n    wlan.connect(WIFI_SSID, WIFI_PASSWORD)\n\n    for _ in range(20):\n        if wlan.isconnected():\n            break\n        time.sleep(1)\n\n    if not wlan.isconnected():\n        raise Exception(\"WiFi failed\")\n\n    ip = wlan.ifconfig()[0]\n    lcd_print(\"WiFi OK\", ip)\n    time.sleep(2)\n    return wlan, ip\n\n# ======================\n# MQTT\n# ======================\ndef mqtt_connect():\n    while True:\n        try:\n            client = MQTTClient(CLIENT_ID, BROKER_IP, BROKER_PORT)\n            client.connect()\n            lcd_print(\"MQTT Connected\")\n            time.sleep(1)\n            return client\n        except Exception as e:\n            lcd_print(\"MQTT Retry\", str(e))\n            time.sleep(2)\n\n# ======================\n# MAIN\n# ======================\ndef main():\n    global i2c\n\n    M5.begin()\n    init_mic()  # 🔥 CRITICAL FIX\n\n    try:\n        i2c = I2C(1, scl=Pin(22), sda=Pin(21), freq=400000)\n        wake_mpu()\n    except:\n        pass\n\n    lcd_print(f\"Hello {FULL_NAME}\", \"Booting...\")\n    time.sleep(2)\n\n    wlan, ip = wifi_connect()\n    client = mqtt_connect()\n\n    last_send = 0\n\n    while True:\n        M5.update()\n\n        temp = read_temp()\n        noise = read_noise()\n\n        try:\n            client.check_msg()\n        except:\n            pass\n\n        if time.time() - last_send >= PUBLISH_SECONDS:\n            payload = {\n                \"device_id\": DEVICE_ID,\n                \"ip\": ip,\n                \"location_id\": LOCATION_ID,\n                \"session_id\": SESSION_ID,\n                \"timestamp\": time.time(),\n                \"temperature_f\": temp,\n                \"noise_level_db\": noise\n            }\n\n            try:\n                client.publish(TOPIC, json.dumps(payload))\n                print(payload)\n\n                lcd_print(\n                    \"Publishing\",\n                    f\"{temp}F\",\n                    f\"{noise} dB\",\n                    LOCATION_ID\n                )\n\n            except:\n                client = mqtt_connect()\n\n            last_send = time.time()\n\n        time.sleep(0.05)\n\n# ======================\n# RUN\n# ======================\nmain()","customList":[]}